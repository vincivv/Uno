<link rel="stylesheet" href="/css/game.css">

<div class="game-container">
    <input id="game-id" type="hidden" value="<%= gameId %>">
    <script src="/js/game.js" defer></script>

    <div class="uno-table-wrapper">
        
        <div class="table-section top-player">
            <div id="opponent-info-panel" class="player-hud-label">Waiting for Opponents...</div>
            <div id="opponent-hand" class="card-row"></div>
        </div>

        <div class="table-section center-play-area">
            <div class="center-notification-hub">
                <div id="game-message" class="game-announcement">Initializing match tabletop engine...</div>
                <div id="error-message" class="game-error-toast"></div>
            </div>

            <div class="deck-arena">
                <div class="deck-stack-wrapper">
                    <div class="deck-label">DRAW DECK</div>
                    <div id="draw-deck" class="deck-card-slot"></div>
                </div>
                
                <div class="deck-stack-wrapper">
                    <div class="deck-label">DISCARD PILE</div>
                    <div id="discard-pile" class="discard-slot">
                        <div class="discard-placeholder">Empty</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-section bottom-player">
            <div id="local-player-label" class="player-hud-label">YOUR HAND</div>
            <div id="player-hand" class="card-row"></div>
        </div>
    </div>

    <div class="game-sidebar-hud">
        <div class="sidebar-start-action">
            <button id="start-game" class="ctrl-btn green-btn">Start Match</button>
        </div>

        <div class="hud-section">
            <h3>MATCH STATS</h3>
            <hr class="hud-divider">
            <div id="game-status" class="hud-stat-box">Loading stats...</div>
        </div>

        <div class="hud-section">
            <h3>PLAYER ROSTER</h3>
            <hr class="hud-divider">
            <div id="players-list" class="roster-container"></div>
        </div>

        <div class="hud-actions">
            <button id="draw-card" class="ctrl-btn blue-btn">Draw Card</button>
            <button id="end-turn" class="ctrl-btn red-btn">End Turn</button>

            <div class="uno-action-row">
                <button id="shout-uno" class="ctrl-btn green-btn uno-square-btn">Shout UNO</button>
                <button id="catch-uno" class="ctrl-btn red-btn uno-square-btn">Catch UNO</button>
            </div>
        </div>
    </div>
</div>
