<link rel="stylesheet" href="/css/lobby.css">

<div class="lobby-wrapper">
    <div class="lobby-header">
        <h2 class="lobby-title">UNO Lobby</h2>
        <script src="/js/lobby.js" defer></script>
        <button id="create-game" class="btn-create">+ Create Game</button>
    </div>
    
    <div class="user-info-bar">
        <div class="user-avatar-placeholder">
            <span class="user-initial"><%= user.email.charAt(0).toUpperCase() %></span>
        </div>
        <div class="user-text">
            <p class="logged-in-text">Logged in as: <span class="email-highlight"><%= user.email %></span></p>
            <p class="lobby-subtitle">Join an active game or start your own!</p>
        </div>
    </div>
    
    <section class="games-section">
        <template id="game-template">
            <div class="game-card">
                <h3 class="game-id">Uno Game #</h3>
                <p class="status-text">Status: <span>waiting</span></p>
                <button class="join-game" type="button">Join Match</button>
            </div>
        </template>
        
        <div id="games-list">
            <p style="color: #666;">Loading games...</p>
        </div>
    </section>
</div>